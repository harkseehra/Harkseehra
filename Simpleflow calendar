<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#ffffff">
<title>Simple Flow</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
<style>
:root {
  --kon:#2196D4;--kon-p:#1A7BB8;--kon-s:#EAF4FB;--kon-g:rgba(33,150,212,0.12);
  --bg:#FFF;--bg2:#F2F2F7;--bg3:#FFFFFF;--sep:rgba(60,60,67,0.12);--sepo:#E5E5EA;
  --l1:#000;--l2:rgba(60,60,67,0.6);--l3:rgba(60,60,67,0.3);--l4:rgba(60,60,67,0.18);
  --red:#FF3B30;--nb-bg:rgba(255,255,255,0.72);--sh-bg:#F2F2F7;--tog-off:#E9E9EB;
  --card-border:0.5px solid #E5E5EA;--scrim:rgba(0,0,0,0.32);
  --f:'Inter',-apple-system,BlinkMacSystemFont,system-ui,sans-serif;
  --sprM:cubic-bezier(0.32,0.72,0,1);--spr:cubic-bezier(0.175,0.885,0.32,1.1);
  --eo:cubic-bezier(0.25,1,0.5,1);--eio:cubic-bezier(0.42,0,0.58,1);
  --st:env(safe-area-inset-top,0px);--sb:env(safe-area-inset-bottom,0px);
}

/* ═══ Dark Mode ═══ */
#app.dark {
  --bg:#000000;--bg2:#1C1C1E;--bg3:#2C2C2E;--sep:rgba(84,84,88,0.36);--sepo:rgba(56,56,58,1);
  --l1:#FFFFFF;--l2:rgba(235,235,245,0.6);--l3:rgba(235,235,245,0.3);--l4:rgba(235,235,245,0.18);
  --nb-bg:rgba(0,0,0,0.72);--sh-bg:#1C1C1E;--tog-off:#39393D;
  --card-border:0.5px solid rgba(56,56,58,1);--scrim:rgba(0,0,0,0.5);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-font-smoothing:antialiased}
html{height:100%}
body{height:100%;width:100%;font-family:var(--f);background:#1a1a1a;overflow:hidden;-webkit-tap-highlight-color:transparent;touch-action:manipulation;letter-spacing:-0.01em}
#app{width:100%;max-width:430px;height:100dvh;margin:0 auto;background:var(--bg);position:relative;overflow:hidden;display:flex;flex-direction:column}
button{font-family:var(--f);cursor:pointer;border:none;background:none;-webkit-appearance:none;letter-spacing:-0.01em;touch-action:manipulation}
input,textarea,select{font-family:var(--f);-webkit-appearance:none;border:none;outline:none;letter-spacing:-0.01em}
::-webkit-scrollbar{display:none}

.nb{display:flex;align-items:center;justify-content:space-between;padding:0 16px;position:relative;z-index:10;flex-shrink:0;height:44px;background:var(--nb-bg);backdrop-filter:saturate(180%) blur(20px);-webkit-backdrop-filter:saturate(180%) blur(20px)}
.nb-sub{border-bottom:0.33px solid var(--sepo)}
.ns{width:48px;display:flex;align-items:center}.ns.r{justify-content:flex-end}
/* Large title area — sits below controls */
.lt{padding:2px 20px 14px;flex-shrink:0;background:var(--bg);border-bottom:0.33px solid var(--sepo)}
.lt-text{font-size:34px;font-weight:700;color:var(--l1);letter-spacing:-0.7px;transition:opacity .3s var(--eo),transform .3s var(--eo)}
.lt-text.sl{animation:tsl .35s var(--eo)}.lt-text.sr{animation:tsr .35s var(--eo)}
/* Compact inline title for sub-screens (day view, sheets) */
.nt{flex:1;text-align:center;font-size:17px;font-weight:600;color:var(--l1);letter-spacing:-0.4px;transition:opacity .3s var(--eo),transform .3s var(--eo)}
.nt.sl{animation:tsl .35s var(--eo)}.nt.sr{animation:tsr .35s var(--eo)}

/* Hamburger — clean, symmetric, centered */
.hm{width:44px;height:44px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;padding:0;transition:transform .15s var(--spr)}
.hm:active{transform:scale(0.82)}
.hm i{display:block;width:21px;height:1.6px;background:var(--l1);border-radius:1px;transition:all .32s var(--spr);transform-origin:center center}
.hm.x i:nth-child(1){transform:rotate(45deg) translate(0px,0px);width:19px}
.hm.x i:nth-child(2){opacity:0;transform:scaleX(0)}
.hm.x i:nth-child(3){transform:rotate(-45deg) translate(0px,0px);width:19px}
/* Fix gap collapse in X state */
.hm.x{gap:0}
.hm.x i:nth-child(1){margin-bottom:-1.6px}
.hm.x i:nth-child(3){margin-top:-1.6px}

.tb{width:34px;height:34px;border-radius:50%;border:1.5px solid var(--kon);color:var(--kon);font-weight:600;font-size:13px;letter-spacing:-0.3px;display:flex;align-items:center;justify-content:center;transition:transform .15s var(--spr),background .2s}
.tb:active{transform:scale(0.88);background:var(--kon-s)}

.ch{display:grid;grid-template-columns:repeat(7,1fr);padding:0 12px}
.ch span{text-align:center;font-size:13px;font-weight:500;color:var(--l2);padding:10px 0 6px}
.csep{height:0.33px;background:var(--sepo);margin:0 12px}
.cg{display:grid;grid-template-columns:repeat(7,1fr);padding:0 12px;transition:opacity .25s var(--eo)}
.cg.al{animation:csl .36s var(--eo)}.cg.ar{animation:csr .36s var(--eo)}

.cl{aspect-ratio:1;display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;padding:0;background:none;transition:transform .1s var(--eo)}
.cl:active{transform:scale(0.92)}.cl.ot{pointer-events:none}
.cc{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;transition:all .32s var(--spr);position:relative}
.cc.td{background:var(--kon);box-shadow:0 2px 12px var(--kon-g)}
.cc.se{background:var(--kon-s);animation:pop .32s var(--spr)}
.cn{font-size:17px;font-weight:400;color:var(--l1);letter-spacing:-0.3px;position:relative;z-index:1}
.cl.ot .cn{color:var(--l4)}.cc.td .cn{color:#fff;font-weight:500}.cc.se .cn{color:var(--kon);font-weight:500}
.ds{display:flex;gap:3px;position:absolute;bottom:2px}
.dt{width:4.5px;height:4.5px;border-radius:50%;background:var(--kon);transition:transform .3s var(--spr)}
.cc.td~.ds .dt{background:rgba(255,255,255,0.9)}

.pv{margin:10px 16px 0;display:flex;flex-direction:column;gap:6px;transform-origin:top center;animation:pvIn .36s var(--sprM)}
.pe{display:flex;align-items:center;gap:12px;background:var(--bg2);border-radius:12px;padding:12px 14px;transition:transform .12s var(--eo)}
.pe:active{transform:scale(0.97)}
.pb{width:3px;height:28px;border-radius:2px;background:var(--kon);flex-shrink:0}
.pt{font-size:15px;font-weight:500;color:var(--l1);letter-spacing:-0.2px}
.pm{font-size:13px;color:var(--l2);margin-top:1px;letter-spacing:-0.1px}
.px{background:var(--bg2);border-radius:12px;padding:14px;text-align:center}.px-t{color:var(--l3);font-size:15px}.px-s{color:var(--l4);font-size:12px;margin-top:3px}

.cw{padding:12px 16px calc(16px + var(--sb));flex-shrink:0}
.cb{width:100%;height:52px;border-radius:14px;background:var(--kon);color:#fff;font-size:17px;font-weight:600;letter-spacing:-0.3px;display:flex;align-items:center;justify-content:center;transition:transform .15s var(--spr),background .15s;box-shadow:0 2px 16px var(--kon-g)}
.cb:active{transform:scale(0.965);background:var(--kon-p)}

.sc{display:none;flex-direction:column;flex:1;overflow:hidden}.sc.on{display:flex}

.dv{position:absolute;inset:0;background:var(--bg);z-index:50;display:flex;flex-direction:column;animation:sUp .48s var(--sprM)}
.dv.cl2{animation:sDn .34s var(--eo) forwards}
.dvs{flex:1;overflow-y:auto;padding:20px 0;-webkit-overflow-scrolling:touch}
.em{display:flex;flex-direction:column;align-items:center;justify-content:center;height:65%;gap:14px;padding:0 40px}
.em svg{opacity:0;animation:fIn .5s var(--spr) .15s forwards}
.em-t{font-size:24px;font-weight:600;color:var(--l1);letter-spacing:-0.5px;opacity:0;animation:fIn .5s var(--spr) .22s forwards}
.em-s{font-size:17px;color:var(--l2);text-align:center;line-height:1.4;opacity:0;animation:fIn .5s var(--spr) .28s forwards}

.tr{display:flex;gap:12px;padding:0 20px;margin-bottom:10px;opacity:0;animation:rUp .4s var(--sprM) forwards}
.tt{width:58px;text-align:right;font-size:15px;font-weight:500;color:var(--l2);padding-top:12px;flex-shrink:0;letter-spacing:-0.2px}
.tba{width:3px;border-radius:2px;background:var(--kon);flex-shrink:0}
.tc{flex:1;background:var(--bg3);border-radius:12px;padding:12px 14px;border:var(--card-border);transition:transform .12s var(--eo),box-shadow .2s}
.tc:active{transform:scale(0.98);box-shadow:0 2px 12px rgba(0,0,0,0.04)}
.tc-t{font-size:17px;font-weight:600;color:var(--l1);letter-spacing:-0.3px}
.tc-l{font-size:15px;color:var(--l2);margin-top:3px;letter-spacing:-0.1px}
.tc-d{font-size:12px;color:var(--l3);margin-top:3px}
.am{padding:24px 20px;text-align:center}.am button{color:var(--kon);font-size:17px;font-weight:600;letter-spacing:-0.3px;transition:transform .12s var(--eo),opacity .15s}.am button:active{transform:scale(0.95);opacity:0.7}

.bk{color:var(--kon);font-size:17px;font-weight:400;display:flex;align-items:center;gap:6px;letter-spacing:-0.3px;transition:transform .12s var(--eo),opacity .15s}
.bk:active{transform:scale(0.94);opacity:0.6}
.bk svg{transition:transform .12s var(--eo)}.bk:active svg{transform:translateX(-2px)}

.sm{position:absolute;inset:0;z-index:80;background:rgba(0,0,0,0);pointer-events:none;transition:background .36s var(--eo)}
.sm.on{background:var(--scrim);pointer-events:auto}
.dw{position:absolute;top:0;bottom:0;left:0;width:80%;max-width:320px;background:var(--bg);z-index:85;display:flex;flex-direction:column;transform:translateX(-101%);transition:transform .42s var(--sprM);will-change:transform}
.dw.on{transform:translateX(0);box-shadow:8px 0 40px rgba(0,0,0,0.08)}
.dh{padding:calc(52px + var(--st)) 24px 20px}
.db{display:flex;align-items:center;gap:12px;margin-bottom:6px}
.dn{font-size:24px;font-weight:700;color:var(--l1);letter-spacing:-0.6px}
.dd{font-size:15px;color:var(--l2);margin-left:44px;letter-spacing:-0.1px}
.dsp{height:0.33px;background:var(--sepo);margin:0 24px 12px}
.di-w{flex:1;padding:0 8px}
.di{display:flex;align-items:center;gap:16px;width:100%;height:52px;padding:0 16px;position:relative;border-radius:10px;color:var(--l2);margin-bottom:2px;transition:background .2s var(--eo),transform .12s var(--eo)}
.di:active{transform:scale(0.97);background:var(--bg2)}
.di.on{color:var(--kon);background:var(--kon-s)}
.di svg{flex-shrink:0}.di span{font-size:17px;font-weight:500;color:var(--l1);letter-spacing:-0.2px}
.di.on span{color:var(--kon);font-weight:600}
.df{padding:20px 24px calc(20px + var(--sb));font-size:12px;color:var(--l3);letter-spacing:-0.1px}

.ss{position:absolute;inset:0;z-index:90;background:rgba(0,0,0,0);pointer-events:none;transition:background .36s var(--eo)}
.ss.on{background:var(--scrim);pointer-events:auto}
.sh{position:absolute;bottom:0;left:0;right:0;height:92%;background:var(--sh-bg);border-radius:14px 14px 0 0;z-index:100;display:flex;flex-direction:column;transform:translateY(100%);transition:transform .46s var(--sprM);box-shadow:0 -2px 40px rgba(0,0,0,0.10);will-change:transform}
.sh.on{transform:translateY(0)}
.sp-w{display:flex;justify-content:center;padding:8px 0 2px}.sp{width:36px;height:5px;border-radius:3px;background:var(--l4)}
.stp{display:flex;align-items:center;justify-content:space-between;padding:6px 20px 10px}
.stc{color:var(--kon);font-size:17px;font-weight:400;letter-spacing:-0.3px;transition:opacity .12s}.stc:active{opacity:0.5}
.sth{font-size:17px;font-weight:600;color:var(--l1);letter-spacing:-0.3px}
.sts{font-size:17px;font-weight:600;letter-spacing:-0.3px;transition:opacity .2s,color .2s}.sts.a{color:var(--kon)}.sts.o{color:var(--l4);pointer-events:none}.sts:active{opacity:0.5}
.ssc{flex:1;overflow-y:auto;padding:8px 0 60px;-webkit-overflow-scrolling:touch}

.fg{background:var(--bg3);border-radius:12px;margin:0 16px 12px;overflow:hidden;animation:gfi .32s var(--eo) both}
.fg:nth-child(1){animation-delay:0s}.fg:nth-child(2){animation-delay:.04s}.fg:nth-child(3){animation-delay:.08s}.fg:nth-child(4){animation-delay:.12s}.fg:nth-child(5){animation-delay:.16s}
.fr{display:flex;align-items:center;justify-content:space-between;padding:13px 16px;min-height:46px;gap:12px}
.fs{height:0.33px;background:var(--sepo);margin:0 16px}
.fl{font-size:17px;color:var(--l1);white-space:nowrap;letter-spacing:-0.2px}
.fv{font-size:17px;color:var(--kon);text-align:right;letter-spacing:-0.2px}
.fi{font-size:17px;color:var(--l1);background:transparent;width:100%;letter-spacing:-0.2px}.fi::placeholder{color:var(--l3)}.fi.b{font-weight:600}
.fta{font-size:17px;color:var(--l1);background:transparent;width:100%;resize:none;min-height:72px;line-height:1.45;letter-spacing:-0.2px}.fta::placeholder{color:var(--l3)}

.tg{width:51px;height:31px;border-radius:16px;position:relative;flex-shrink:0;padding:0;transition:background .28s var(--eio)}
.tg.on{background:var(--kon)}.tg.of{background:var(--tog-off)}
.tk{width:27px;height:27px;border-radius:50%;background:#fff;position:absolute;top:2px;box-shadow:0 1px 4px rgba(0,0,0,0.12),0 0 1px rgba(0,0,0,0.04);transition:left .28s var(--spr)}
.tg.on .tk{left:22px}.tg.of .tk{left:2px}

.rl{overflow:hidden;animation:exD .32s var(--sprM)}
.ro{padding:13px 16px 13px 36px;display:flex;align-items:center;justify-content:space-between;transition:background .15s}
.ro:active{background:var(--bg2)}.ro.on{background:var(--kon-s)}
.ro span{font-size:17px;color:var(--l1);letter-spacing:-0.2px}.ro.on span{color:var(--kon)}

.dlr{text-align:center;padding:13px 16px;color:var(--red);font-size:17px;letter-spacing:-0.2px;transition:background .15s}.dlr:active{background:rgba(255,59,48,0.06)}
.dlc{padding:16px;text-align:center}.dlc-t{font-size:15px;color:var(--l2);margin-bottom:14px}
.dlb{display:flex;gap:12px}
.dlx{flex:1;padding:12px;border-radius:12px;border:0.5px solid var(--sepo);background:var(--bg3);font-size:16px;color:var(--l1);font-weight:500;transition:transform .12s var(--eo)}.dlx:active{transform:scale(0.96)}
.dld{flex:1;padding:12px;border-radius:12px;background:var(--red);color:#fff;font-size:16px;font-weight:600;transition:transform .12s var(--eo)}.dld:active{transform:scale(0.96)}

.el{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;background:var(--bg2)}
.sh2{position:sticky;top:0;z-index:5;padding:16px 20px 8px;background:var(--bg2);backdrop-filter:saturate(160%) blur(16px);-webkit-backdrop-filter:saturate(160%) blur(16px);font-size:22px;font-weight:700;color:var(--l1);letter-spacing:-0.5px;opacity:0.96}
.er{display:flex;align-items:center;padding:14px 20px;gap:14px;background:transparent;transition:background .15s,transform .12s var(--eo);opacity:0;animation:rUp .4s var(--sprM) forwards}
.er:active{background:rgba(0,0,0,0.03);transform:scale(0.99)}
.eb{width:3px;height:40px;border-radius:2px;background:var(--kon);flex-shrink:0}
.ey{flex:1}.ey-t{font-size:17px;font-weight:600;color:var(--l1);letter-spacing:-0.3px}
.ey-m{font-size:15px;color:var(--l2);margin-top:2px;letter-spacing:-0.1px}
.ey-l{font-size:12px;color:var(--l3);margin-top:3px;display:flex;align-items:center;gap:4px;letter-spacing:-0.1px}
.ec{color:var(--l4);flex-shrink:0;opacity:0.6}
.es{height:0.33px;background:var(--sepo);margin:0 20px 0 52px}

.bn{position:absolute;top:calc(10px + var(--st));left:14px;right:14px;z-index:200;background:#1C1C1E;border-radius:16px;padding:16px 18px;display:flex;align-items:center;gap:14px;box-shadow:0 8px 32px rgba(0,0,0,0.22);animation:bDr .44s var(--sprM);transition:transform .3s var(--eo),opacity .3s}
.bn.ou{transform:translateY(-100px) scale(0.9);opacity:0}
.bi{width:24px;height:24px;border-radius:50%;background:var(--kon);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.bt{font-size:15px;font-weight:600;color:#fff;letter-spacing:-0.2px}
.bs{font-size:13px;color:rgba(255,255,255,0.65);margin-top:2px;letter-spacing:-0.1px}

.ph{display:flex;flex-direction:column;align-items:center;justify-content:center;height:65%;gap:14px;padding:40px}
.phi{width:72px;height:72px;border-radius:50%;background:var(--kon-s);display:flex;align-items:center;justify-content:center;font-size:32px;animation:fIn .5s var(--spr) .1s both}
.pht{font-size:24px;font-weight:600;color:var(--l1);letter-spacing:-0.5px;opacity:0;animation:fIn .5s var(--spr) .18s forwards}
.phs{font-size:17px;color:var(--l2);text-align:center;line-height:1.4;opacity:0;animation:fIn .5s var(--spr) .26s forwards}

@keyframes sUp{0%{transform:translateY(100%)}100%{transform:translateY(0)}}
@keyframes sDn{0%{transform:translateY(0)}100%{transform:translateY(100%)}}
@keyframes csl{0%{transform:translateX(50px);opacity:0}100%{transform:translateX(0);opacity:1}}
@keyframes csr{0%{transform:translateX(-50px);opacity:0}100%{transform:translateX(0);opacity:1}}
@keyframes tsl{0%{transform:translateX(24px);opacity:0}100%{transform:translateX(0);opacity:1}}
@keyframes tsr{0%{transform:translateX(-24px);opacity:0}100%{transform:translateX(0);opacity:1}}
@keyframes pop{0%{transform:scale(0.5);opacity:0}60%{transform:scale(1.08)}100%{transform:scale(1);opacity:1}}
@keyframes pvIn{0%{transform:translateY(-10px) scale(0.96);opacity:0}100%{transform:translateY(0) scale(1);opacity:1}}
@keyframes fIn{0%{transform:translateY(20px);opacity:0}100%{transform:translateY(0);opacity:1}}
@keyframes rUp{0%{transform:translateY(16px);opacity:0}100%{transform:translateY(0);opacity:1}}
@keyframes bDr{0%{transform:translateY(-90px) scale(0.9);opacity:0}70%{transform:translateY(4px) scale(1.01)}100%{transform:translateY(0) scale(1);opacity:1}}
@keyframes exD{0%{max-height:0;opacity:0}100%{max-height:500px;opacity:1}}
@keyframes gfi{0%{transform:translateY(10px);opacity:0}100%{transform:translateY(0);opacity:1}}
@keyframes cks{0%{stroke-dashoffset:20}100%{stroke-dashoffset:0}}
@keyframes inkSpread{0%{transform:scale(0);opacity:0.6}50%{opacity:0.3}100%{transform:scale(2.5);opacity:0}}
@keyframes inkSelect{0%{transform:scale(1)}40%{transform:scale(0.85)}100%{transform:scale(1)}}
@keyframes bottleFadeIn{0%{transform:translateY(20px);opacity:0}100%{transform:translateY(0);opacity:1}}

/* Theme transition — smooth accent swap (scoped, doesn't kill other animations) */
#app.theme-transitioning .cc,
#app.theme-transitioning .cb,
#app.theme-transitioning .tba,
#app.theme-transitioning .pb,
#app.theme-transitioning .eb,
#app.theme-transitioning .ev-bar,
#app.theme-transitioning .dt,
#app.theme-transitioning .dot,
#app.theme-transitioning .tb,
#app.theme-transitioning .tg.on,
#app.theme-transitioning .hm i,
#app.theme-transitioning .di.on,
#app.theme-transitioning .ink-item.active,
#app.theme-transitioning .bk,
#app.theme-transitioning .stc,
#app.theme-transitioning .sts.a,
#app.theme-transitioning .fv,
#app.theme-transitioning .am button,
#app.theme-transitioning .bi,
#app.theme-transitioning .ap-check{
  transition:color .45s var(--eo),background-color .45s var(--eo),border-color .45s var(--eo),box-shadow .45s var(--eo) !important;
}
/* Dark mode transition on backgrounds */
#app.theme-transitioning,
#app.theme-transitioning .nb,
#app.theme-transitioning .lt,
#app.theme-transitioning .dw,
#app.theme-transitioning .sh,
#app.theme-transitioning .fg,
#app.theme-transitioning .tc,
#app.theme-transitioning .pv,
#app.theme-transitioning .ev-list,
#app.theme-transitioning .sh2,
#app.theme-transitioning .ink-item,
#app.theme-transitioning .settings-screen,
#app.theme-transitioning .set-group{
  transition:background-color .45s var(--eo),color .45s var(--eo) !important;
}

