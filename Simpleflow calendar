/* ═══ Apply Ink Theme ═══ */
function applyInk(id,animate){
  const ink=INKS.find(i=>i.id===id)||INKS[0];
  const root=document.documentElement;
  const app=document.getElementById('app');
  if(animate){
    app.classList.add('theme-transitioning');
    setTimeout(()=>app.classList.remove('theme-transitioning'),500);
  }
  root.style.setProperty('--kon',ink.c);
  root.style.setProperty('--kon-p',ink.cp);
  root.style.setProperty('--kon-s',ink.cs);
  root.style.setProperty('--kon-g',ink.cg);
  S.ink=id;
  localStorage.setItem('sf-ink',id);
  // Update any hardcoded stroke/fill references
  document.querySelectorAll('[data-ink-stroke]').forEach(el=>el.setAttribute('stroke',ink.c));
