  // Update theme-color meta
  document.querySelector('meta[name="theme-color"]').content=dark?'#000000':'#ffffff';
  // Update body bg
  document.body.style.background=dark?'#000':'#1a1a1a';

  // Re-apply ink to get correct surface tints
  applyInk(S.ink,false);
  // Re-render settings if visible
  if(S.s===3)rSet();
