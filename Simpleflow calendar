let tx=0,ty=0;
document.getElementById('gr').addEventListener('touchstart',e=>{tx=e.touches[0].clientX;ty=e.touches[0].clientY},{passive:true});
document.getElementById('gr').addEventListener('touchend',e=>{const dx=e.changedTouches[0].clientX-tx,dy=e.changedTouches[0].clientY-ty;if(Math.abs(dx)>50&&Math.abs(dx)>Math.abs(dy)){if(dx<0){S.m++;if(S.m>11){S.m=0;S.y++;}rC('l');}else{S.m--;if(S.m<0){S.m=11;S.y--;}rC('r');}}},{passive:true});

function oDV(){
  if(!S.sel)return;S.dvo=true;const d=S.sel,ev=eo(d.toDateString()).sort((a,b)=>a.a?-1:b.a?1:(a.sH*60+a.sM)-(b.sH*60+b.sM)),tm=ev.filter(e=>!e.a);
  let h='<div class="dv"><div class="nb nb-sub"><div class="ns">';
  h+=`<button class="bk" onclick="cDV()"><svg width="10" height="18" viewBox="0 0 10 18" fill="none"><path d="M9 1L1 9L9 17" stroke="var(--kon)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Back</button>`;
  h+=`</div><div class="nt">${fd(d)}</div><div class="ns r"></div></div><div class="dvs">`;
  if(!ev.length){
    h+=`<div class="em"><svg width="72" height="72" viewBox="0 0 72 72" fill="none"><rect x="12" y="16" width="48" height="44" rx="6" stroke="var(--kon)" stroke-width="2"/><line x1="12" y1="28" x2="60" y2="28" stroke="var(--kon)" stroke-width="2"/><line x1="26" y1="12" x2="26" y2="20" stroke="var(--kon)" stroke-width="2" stroke-linecap="round"/><line x1="46" y1="12" x2="46" y2="20" stroke="var(--kon)" stroke-width="2" stroke-linecap="round"/></svg><div class="em-t">No Events</div><div class="em-s">Your day is open.</div><div style="margin-top:16px;width:100%;padding:0 20px;opacity:0;animation:fIn .5s cubic-bezier(0.175,0.885,0.32,1.1) .34s forwards"><button class="cb" onclick="oS()" style="max-width:280px;margin:0 auto">+ Create Event</button></div></div>`;
  }else{
    tm.forEach((e,i)=>{h+=`<div class="tr" style="animation-delay:${i*.07}s"><div class="tt">${ft(e.sH,e.sM)}</div><div class="tba"></div><div class="tc" onclick="oS('${e.id}')"><div class="tc-t">${e.t}</div>${e.l?`<div class="tc-l">${e.l}</div>`:''}<div class="tc-d">${ft(e.sH,e.sM)} – ${ft(e.eH,e.eM)}</div></div></div>`;});
    h+=`<div class="am"><button onclick="oS()">+ Create Another Event</button></div>`;
  }
  h+='</div></div>';
  document.getElementById('dv').innerHTML=h;document.getElementById('dv').style.display='block';document.getElementById('mn').style.display='none';
}
function cDV(){const el=document.getElementById('dv').querySelector('.dv');if(el){el.classList.add('cl2');setTimeout(()=>{S.dvo=false;document.getElementById('dv').style.display='none';document.getElementById('mn').style.display='flex';},320);}}

function tD(){S.dr=!S.dr;document.getElementById('dw').classList.toggle('on',S.dr);document.getElementById('scm').classList.toggle('on',S.dr);document.getElementById('hb').classList.toggle('x',S.dr);}
function nv(s){
  S.s=s;S.dr=false;S.dvo=false;
  document.getElementById('dw').classList.remove('on');document.getElementById('scm').classList.remove('on');document.getElementById('hb').classList.remove('x');
  document.getElementById('dv').style.display='none';document.getElementById('mn').style.display='flex';
  for(let i=0;i<4;i++)document.getElementById('s'+i).classList.toggle('on',i===s);
  document.querySelectorAll('.di').forEach(el=>el.classList.toggle('on',parseInt(el.dataset.s)===s));
  const ts=[`${M[S.m]} ${S.y}`,'Events','Themes','Settings'];document.getElementById('nT').textContent=ts[s];
  const ltw=document.getElementById('ltWrap');
  ltw.style.background=s===0?'var(--bg)':'var(--bg2)';
  const nr=document.getElementById('nR');
  if(s===0)nr.innerHTML=`<button class="tb" onclick="gT()">${new Date().getDate()}</button>`;
  else if(s===1)nr.innerHTML=`<button style="color:var(--kon);font-size:28px;font-weight:300;width:44px;height:44px;display:flex;align-items:center;justify-content:center;transition:transform .12s" onclick="oS()" onmousedown="this.style.transform='scale(0.85)'" onmouseup="this.style.transform=''" ontouchstart="this.style.transform='scale(0.85)'" ontouchend="this.style.transform=''">+</button>`;
  else nr.innerHTML='';
  if(s===1)rEL();if(s===2)rInk();if(s===3)rSet();document.getElementById('app').style.background=s===0?'var(--bg)':'var(--bg2)';
}

function rEL(){
  const el=document.getElementById('eL'),td=new Date(),tm=new Date(Date.now()+864e5);
  const so=[...S.evs].sort((a,b)=>new Date(a.d)-new Date(b.d)||(a.sH*60+a.sM)-(b.sH*60+b.sM));
  const bk={Today:[],Tomorrow:[],'This Week':[],'Next Week':[],'This Month':[],Later:[]};
  so.forEach(e=>{const d=new Date(e.d);if(d.toDateString()===td.toDateString())bk.Today.push(e);else if(d.toDateString()===tm.toDateString())bk.Tomorrow.push(e);else if(d>td&&d<new Date(Date.now()+7*864e5))bk['This Week'].push(e);else if(d>=new Date(Date.now()+7*864e5)&&d<new Date(Date.now()+14*864e5))bk['Next Week'].push(e);else if(d.getMonth()===td.getMonth()&&d.getFullYear()===td.getFullYear())bk['This Month'].push(e);else bk.Later.push(e);});
  if(!Object.values(bk).some(b=>b.length)){el.innerHTML=`<div class="em" style="height:60vh"><svg width="64" height="64" viewBox="0 0 64 64" fill="none"><rect x="10" y="14" width="44" height="40" rx="6" stroke="var(--kon)" stroke-width="2"/><line x1="10" y1="24" x2="54" y2="24" stroke="var(--kon)" stroke-width="2"/></svg><div class="em-t">Nothing Scheduled</div><div class="em-s">Your upcoming events will appear here.</div><div style="margin-top:12px;opacity:0;animation:fIn .5s cubic-bezier(0.175,0.885,0.32,1.1) .3s forwards"><button class="cb" style="padding:0 32px;width:auto" onclick="oS()">+ Create Event</button></div></div>`;return;}
  let h='',idx=0;
  Object.entries(bk).forEach(([l,evs])=>{if(!evs.length)return;h+=`<div class="sh2">${l}</div>`;
    evs.forEach(e=>{h+=`<div class="er" style="animation-delay:${idx*.04}s" onclick="oS('${e.id}')"><div class="eb"></div><div class="ey"><div class="ey-t">${e.t}</div><div class="ey-m">${e.a?'All Day':ft(e.sH,e.sM)+' – '+ft(e.eH,e.eM)}</div>${e.l?`<div class="ey-l"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M5 .5C3 .5 1.5 2.2 1.5 4.3c0 2.8 3.5 5.2 3.5 5.2s3.5-2.4 3.5-5.2C8.5 2.2 7 .5 5 .5z" fill="rgba(60,60,67,0.3)"/></svg>${e.l}</div>`:''}</div><svg class="ec" width="8" height="14" viewBox="0 0 8 14" fill="none"><path d="M1 1L7 7L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div class="es"></div>`;idx++;});});
  el.innerHTML=h;
}

function oS(eid){
  let ev=null;if(eid)ev=S.evs.find(e=>e.id===eid);S.ed=ev;S.sho=true;
  const d=ev?new Date(ev.d):(S.sel||new Date()),isE=!!ev,ad=ev?ev.a:false,rem=ev?ev.r:'None';
  let h='<div class="sp-w"><div class="sp"></div></div>';
  h+=`<div class="stp"><button class="stc" onclick="cS()">Cancel</button><span class="sth">${isE?'Edit Event':'New Event'}</span><button id="sB" class="sts o" onclick="svE()">Save</button></div><div class="ssc">`;
  h+=`<div class="fg"><div class="fr"><input class="fi b" id="fT" placeholder="Event Title" value="${ev?ev.t:''}" oninput="cK()"></div><div class="fs"></div><div class="fr" style="gap:10px"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 1C4.7 1 2 3.7 2 7c0 4.5 6 8 6 8s6-3.5 6-8c0-3.3-2.7-6-6-6zm0 8a2 2 0 110-4 2 2 0 010 4z" fill="rgba(60,60,67,0.4)"/></svg><input class="fi" id="fL" placeholder="Location or Video Link" value="${ev?ev.l:''}"></div></div>`;
  h+=`<div class="fg"><div class="fr"><span class="fl">Date</span><span class="fv">${M[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}</span></div>`;
  h+=`<div id="tR" style="${ad?'display:none':''}"><div class="fs"></div><div class="fr"><span class="fl">Starts</span><div style="display:flex;gap:6px"><select id="fSH" class="fv" style="background:transparent">`;
  for(let i=0;i<24;i++)h+=`<option value="${i}"${(ev?ev.sH:9)===i?' selected':''}>${ft(i,0)}</option>`;
  h+=`</select><select id="fSM" class="fv" style="background:transparent">`;[0,15,30,45].forEach(m=>h+=`<option value="${m}"${(ev?ev.sM:0)===m?' selected':''}>${m.toString().padStart(2,'0')}</option>`);
  h+=`</select></div></div><div class="fs"></div><div class="fr"><span class="fl">Ends</span><div style="display:flex;gap:6px"><select id="fEH" class="fv" style="background:transparent">`;
  for(let i=0;i<24;i++)h+=`<option value="${i}"${(ev?ev.eH:10)===i?' selected':''}>${ft(i,0)}</option>`;
  h+=`</select><select id="fEM" class="fv" style="background:transparent">`;[0,15,30,45].forEach(m=>h+=`<option value="${m}"${(ev?ev.eM:0)===m?' selected':''}>${m.toString().padStart(2,'0')}</option>`);
  h+=`</select></div></div></div>`;
  h+=`<div class="fs"></div><div class="fr"><span class="fl">All Day</span><button class="tg ${ad?'on':'of'}" id="tA" onclick="tAD()"><div class="tk"></div></button></div></div>`;
  h+=`<div class="fg"><div class="fr" onclick="tRM()" style="cursor:pointer"><span class="fl">Reminder</span><div style="display:flex;align-items:center;gap:6px"><span class="fv" id="rV">${rem}</span><svg id="rC" width="8" height="14" viewBox="0 0 8 14" fill="none" style="transition:transform .25s var(--spr)"><path d="M1 1L7 7L1 13" stroke="rgba(60,60,67,0.3)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div></div><div id="rO" style="display:none"></div></div>`;
  h+=`<div class="fg"><div style="padding:13px 16px"><textarea class="fta" id="fN" placeholder="Add notes…">${ev?ev.n:''}</textarea></div></div>`;
  if(isE)h+=`<div class="fg" id="dG"><div class="dlr" onclick="cD()">Delete Event</div></div>`;
  h+='</div>';
  document.getElementById('sh').innerHTML=h;
  requestAnimationFrame(()=>{document.getElementById('ssm').classList.add('on');document.getElementById('sh').classList.add('on');});
  setTimeout(()=>document.getElementById('fT')?.focus(),450);cK();
}
function cS(){document.getElementById('sh').classList.remove('on');document.getElementById('ssm').classList.remove('on');setTimeout(()=>{S.sho=false;S.ed=null;},420);}
function cK(){const b=document.getElementById('sB'),t=document.getElementById('fT')?.value?.trim();if(b)b.className='sts '+(t?'a':'o');}
function tAD(){const t=document.getElementById('tA'),on=t.classList.contains('on');t.classList.toggle('on',!on);t.classList.toggle('of',on);document.getElementById('tR').style.display=on?'':'none';}
function tRM(){
  const el=document.getElementById('rO'),ch=document.getElementById('rC');
  if(el.style.display==='none'){const cur=document.getElementById('rV').textContent;let h='<div class="rl">';
    RM.forEach(r=>{h+=`<div class="fs"></div><div class="ro${r===cur?' on':''}" onclick="sR('${r}')"><span>${r}</span>${r===cur?'<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8L6.5 11.5L13 4.5" stroke="var(--kon)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>':''}</div>`;});
    el.innerHTML=h+'</div>';el.style.display='block';ch.style.transform='rotate(90deg)';
  }else{el.style.display='none';ch.style.transform='';}
}
function sR(r){document.getElementById('rV').textContent=r;document.getElementById('rO').style.display='none';document.getElementById('rC').style.transform='';}
function cD(){document.getElementById('dG').innerHTML=`<div class="dlc"><div class="dlc-t">Are you sure?</div><div class="dlb"><button class="dlx" onclick="xD()">Cancel</button><button class="dld" onclick="dE()">Delete</button></div></div>`;}
function xD(){document.getElementById('dG').innerHTML='<div class="dlr" onclick="cD()">Delete Event</div>';}
function dE(){if(S.ed)S.evs=S.evs.filter(e=>e.id!==S.ed.id);cS();setTimeout(()=>{if(S.dvo)oDV();rC();if(S.s===1)rEL();},440);}
function svE(){
  const title=document.getElementById('fT').value.trim();if(!title)return;
  const d=S.ed?new Date(S.ed.d):(S.sel||new Date()),ad=document.getElementById('tA').classList.contains('on');
  const ev={id:S.ed?S.ed.id:gi(),t:title,d:d.toDateString(),sH:parseInt(document.getElementById('fSH')?.value||9),sM:parseInt(document.getElementById('fSM')?.value||0),eH:parseInt(document.getElementById('fEH')?.value||10),eM:parseInt(document.getElementById('fEM')?.value||0),l:document.getElementById('fL').value,n:document.getElementById('fN').value,a:ad,r:document.getElementById('rV').textContent};
  if(S.ed)S.evs=S.evs.map(e=>e.id===ev.id?ev:e);else S.evs.push(ev);
  cS();setTimeout(()=>{sB(ev);if(S.dvo)oDV();rC();if(S.s===1)rEL();},440);
}
function sB(ev){const el=document.getElementById('bn');el.className='bn';el.style.display='flex';el.innerHTML=`<div class="bi"><svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M2 6.5L5.5 10L11 3.5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="stroke-dasharray:20;stroke-dashoffset:20;animation:cks .35s ease .25s forwards"/></svg></div><div><div class="bt">Event ${S.ed?'Updated':'Created'}</div><div class="bs">${ev.t} · ${ev.a?'All Day':ft(ev.sH,ev.sM)}</div></div>`;el.onclick=kB;setTimeout(kB,3500);}
function kB(){const el=document.getElementById('bn');if(el.style.display==='none')return;el.classList.add('ou');setTimeout(()=>{el.style.display='none';el.className='bn';},320);}

document.getElementById('dD').textContent=fd(new Date());
document.getElementById('nR').innerHTML=`<button class="tb" onclick="gT()">${new Date().getDate()}</button>`;
applyMode(S.mode,false);
applyInk(S.ink,false);
rC();
</script>
</body>
